{
  "name": "ink-lang",
  "displayName": "Ink Language",
  "description": "Syntax highlighting for inkle's Ink scripting language (.ink files)",
  "version": "0.1.0",
  "publisher": "fmv-game",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ink",
        "aliases": ["Ink", "ink"],
        "extensions": [".ink"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ink",
        "scopeName": "source.ink",
        "path": "./syntaxes/ink.tmLanguage.json"
      }
    ]
  }
}
