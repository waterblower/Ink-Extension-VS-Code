{
    "name": "inkup",
    "displayName": "Inkup: yet another Ink language support and more things",
    "description": "Syntax highlighting for inkle's Ink scripting language (.ink files)",
    "version": "0.2.0",
    "publisher": "water2077",
    "icon": "icon-small.jpg",
    "engines": {
        "vscode": "^1.0.0"
    },
    "repository": {
        "url": "https://github.com/waterblower/Ink-Extension-VS-Code"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./extension.js",
    "activationEvents": [
        "onLanguage:ink"
    ],
    "contributes": {
        "languages": [
            {
                "id": "ink",
                "aliases": [
                    "Ink",
                    "ink"
                ],
                "extensions": [
                    ".ink"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "ink",
                "scopeName": "source.ink",
                "path": "./syntaxes/ink.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "ink.generateAudio",
                "title": "生成语音"
            },
            {
                "command": "ink.generateImage",
                "title": "生成图片"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "ink.generateAudio",
                    "when": "editorHasSelection && resourceLangId == ink",
                    "group": "ink@1"
                },
                {
                    "command": "ink.generateImage",
                    "when": "editorHasSelection && resourceLangId == ink",
                    "group": "ink@1"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": []
        },
        "views": {
            "ink-sidebar": [
                {
                    "type": "webview",
                    "id": "ink.counterView",
                    "name": "Counter"
                }
            ]
        }
    },
    "dependencies": {
        "@types/vscode": "^1.110.0",
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    }
}
