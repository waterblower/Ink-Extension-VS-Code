{
    "name": "inkup",
    "displayName": "Inkup: Ink language support",
    "description": "Language support for inkle's Ink scripting language: syntax highlighting, compiler diagnostics, go to definition, find references, formatting and image previews.",
    "version": "0.3.0",
    "publisher": "water2077",
    "icon": "icon-small.jpg",
    "engines": {
        "vscode": "^1.75.0"
    },
    "repository": {
        "url": "https://github.com/waterblower/Ink-Extension-VS-Code"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [
        "onLanguage:ink"
    ],
    "contributes": {
        "languages": [
            {
                "id": "ink",
                "aliases": [
                    "Ink",
                    "ink"
                ],
                "extensions": [
                    ".ink"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "ink",
                "scopeName": "source.ink",
                "path": "./syntaxes/ink.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "build": "node esbuild.mjs",
        "watch": "node esbuild.mjs --watch",
        "typecheck": "tsc --noEmit",
        "package": "pnpm run typecheck && pnpm run build && vsce package --no-dependencies"
    },
    "dependencies": {
        "inkjs": "^2.4.0"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "@types/vscode": "1.75.0",
        "esbuild": "^0.27.4",
        "typescript": "^5.9.3"
    }
}
