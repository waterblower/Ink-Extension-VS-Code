{
  "name": "ink-lang",
  "displayName": "Ink Language",
  "description": "Syntax highlighting for inkle's Ink scripting language (.ink files)",
  "version": "0.2.0",
  "publisher": "water2077",
  "icon": "inky-icon.png",
  "engines": {
    "vscode": "^1.0.0"
  },
  "repository": {
    "url": "https://github.com/waterblower/Ink-Extension-VS-Code"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ink",
        "aliases": [
          "Ink",
          "ink"
        ],
        "extensions": [
          ".ink"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ink",
        "scopeName": "source.ink",
        "path": "./syntaxes/ink.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "ink.generateAudio",
        "title": "生成语音"
      },
      {
        "command": "ink.generateImage",
        "title": "生成图片"
      },
      {
        "command": "ink.openCounter",
        "title": "Ink: Open Counter",
        "icon": "$(symbol-numeric)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ink.generateAudio",
          "when": "editorHasSelection && resourceLangId == ink",
          "group": "ink@1"
        },
        {
          "command": "ink.generateImage",
          "when": "editorHasSelection && resourceLangId == ink",
          "group": "ink@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ink-sidebar",
          "title": "Ink Tools",
          "icon": "inky-icon.png"
        }
      ]
    },
    "views": {
      "ink-sidebar": [
        {
          "type": "webview",
          "id": "ink.counterView",
          "name": "Counter"
        }
      ]
    }
  }
}
