{
    "fmt": {
        "indentWidth": 4
    },
    "tasks": {
        "build": "deno run -A build.ts",
        "watch": "deno run -A build.ts --watch",
        "check": "deno check src/extension.ts",
        "package": "deno task check && deno task build && deno run -A npm:@vscode/vsce package --no-dependencies",
},
    "imports": {
        "@deno/esbuild-plugin": "jsr:@deno/esbuild-plugin@^1.2.1",
        "esbuild": "npm:esbuild@^0.27.4",
        "inkjs/": "npm:/inkjs@^2.4.0/",
        "vscode": "npm:@types/vscode@1.75.0"
    },
    "compilerOptions": {
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true
    },
    "nodeModulesDir": "auto"
}
