{
  "name": "ink-lang",
  "displayName": "Ink Language",
  "description": "Syntax highlighting for inkle's Ink scripting language (.ink files)",
  "version": "0.2.0",
  "publisher": "water2077",
  "icon": "inky-icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "repository": {
    "url": "https://github.com/waterblower/Ink-Extension-VS-Code"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:ink"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ink",
        "aliases": [
          "Ink",
          "ink"
        ],
        "extensions": [
          ".ink"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ink",
        "scopeName": "source.ink",
        "path": "./syntaxes/ink.tmLanguage.json"
      }
    ]
  }
}
