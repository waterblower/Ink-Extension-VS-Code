{
    "name": "inkup",
    "displayName": "Inkup: Ink language support",
    "description": "Language support for inkle's Ink scripting language: syntax highlighting, compiler diagnostics, go to definition, find references, formatting and image previews.",
    "version": "0.3.5",
    "publisher": "water2077",
    "icon": "icon-small.jpg",
    "engines": {
        "vscode": "^1.75.0"
    },
    "repository": {
        "url": "https://github.com/waterblower/Ink-Extension-VS-Code"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [
        "onLanguage:ink"
    ],
    "contributes": {
        "languages": [
            {
                "id": "ink",
                "aliases": [
                    "Ink",
                    "ink"
                ],
                "extensions": [
                    ".ink"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "ink",
                "scopeName": "source.ink",
                "path": "./syntaxes/ink.tmLanguage.json"
            }
        ]
    }
}
